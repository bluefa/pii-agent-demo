{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-main-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-pr-create.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-codex.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-grep.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-language.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-bash-pr-capture.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-verify.sh",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "agent-skills@addy-agent-skills": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh",
    "padding": 1
  }
}
