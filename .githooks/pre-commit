#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

# DESIGN.md and design-system routing must be checked even for markdown-only commits.
design_changed=$(printf '%s\n' "$staged_files" | grep -cE '^(DESIGN\.md|lib/theme\.ts|app/globals\.css|\.claude/skills/|\.codex/skills/)' || true)
code_changed=$(printf '%s\n' "$staged_files" | grep -cE '\.(ts|tsx|js|jsx|mjs)$' || true)

if [[ "$design_changed" -gt 0 ]]; then
  echo "[pre-commit] Running design check..."
  npm run design:check
fi

echo "[pre-commit] Running contract check..."
bash scripts/contract-check.sh --mode staged

if [[ "$code_changed" -eq 0 ]]; then
  echo "[pre-commit] No code files changed — skipping lint/tsc/build"
  echo "[pre-commit] OK"
  exit 0
fi

echo "[pre-commit] Running lint..."
npm run lint --quiet 2>&1 | tail -3

echo "[pre-commit] Running type-check..."
npx tsc --noEmit --pretty false 2>&1 | tail -3

echo "[pre-commit] Running tests..."
npm run test:run

echo "[pre-commit] Running build..."
npm run build 2>&1 | tail -3

echo "[pre-commit] OK"
